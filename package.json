{
  "name": "clawser",
  "private": true,
  "description": "Browser-native AI agent workspace with tools, memory, and goals.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node web/serve-https.mjs",
    "start:http": "npx serve web/ -l 8080",
    "test": "node web/test/run-tests.mjs --group all",
    "test:fast": "node web/test/run-tests.mjs --group fast",
    "test:core": "node web/test/run-tests.mjs --group core",
    "test:mesh": "node web/test/run-tests.mjs --group mesh",
    "test:mesh-net": "node web/test/run-tests.mjs --group mesh-net",
    "test:mesh-sync": "node web/test/run-tests.mjs --group mesh-sync",
    "test:mesh-identity": "node web/test/run-tests.mjs --group mesh-identity",
    "test:mesh-apps": "node web/test/run-tests.mjs --group mesh-apps",
    "test:mesh-ops": "node web/test/run-tests.mjs --group mesh-ops",
    "test:e2e": "node web/test/run-tests.mjs --group e2e",
    "test:changed": "node web/test/run-tests.mjs --group changed",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest"
  },
  "devDependencies": {
    "ai-matey-middleware-andbox": "^0.1.0",
    "andbox": "^0.1.0",
    "browsermesh-netway": "^0.1.0",
    "browsermesh-pod": "^0.1.0",
    "browsermesh-primitives": "^0.1.0",
    "fflate": "^0.8.2",
    "vitest": "^4.0.18",
    "ws": "^8.18.0",
    "wsh-upon-star": "^0.1.0"
  }
}
