{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://browsermesh.dev/schemas/pod-capability.json",
  "title": "BrowserMesh Pod Capability Schema",
  "description": "Schema for pod capability advertisement and negotiation",
  "type": "object",
  "required": ["id", "kind", "origin", "channels"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Cryptographic pod ID (base64url of SHA-256 of Ed25519 public key)",
      "pattern": "^[a-zA-Z0-9_-]{43}$"
    },
    "slotId": {
      "type": "string",
      "description": "Stable slot ID (survives reload)",
      "pattern": "^slot-[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": ["window", "spawned", "iframe", "worker", "shared-worker", "service-worker", "worklet", "server"],
      "description": "Pod execution context type"
    },
    "origin": {
      "type": "string",
      "format": "uri",
      "description": "Pod's origin (scheme + host + port)"
    },
    "parentId": {
      "type": "string",
      "description": "Parent pod ID (for frames, workers)"
    },
    "openerId": {
      "type": "string",
      "description": "Opener pod ID (for spawned windows)"
    },
    "visibility": {
      "type": "object",
      "properties": {
        "state": {
          "type": "string",
          "enum": ["visible", "hidden", "prerender"]
        },
        "throttled": {
          "type": "boolean",
          "description": "Whether background throttling is active"
        }
      }
    },
    "channels": {
      "type": "object",
      "description": "Available communication channels",
      "properties": {
        "postMessage": {
          "type": "boolean",
          "description": "Can receive postMessage"
        },
        "messagePort": {
          "type": "boolean",
          "description": "Can use MessagePort/MessageChannel"
        },
        "broadcastChannel": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "enum": ["same-origin"] }
          ],
          "description": "BroadcastChannel availability"
        },
        "sharedWorker": {
          "type": "boolean",
          "description": "Can connect to SharedWorker"
        },
        "serviceWorker": {
          "type": "object",
          "properties": {
            "controlled": {
              "type": "boolean",
              "description": "Is controlled by a ServiceWorker"
            },
            "canIntercept": {
              "type": "boolean",
              "description": "Can intercept fetch (is a ServiceWorker)"
            }
          }
        },
        "webSocket": {
          "type": "boolean",
          "description": "Can open WebSocket connections"
        },
        "webTransport": {
          "type": "boolean",
          "description": "Can use WebTransport"
        },
        "webRTC": {
          "type": "object",
          "properties": {
            "dataChannel": {
              "type": "boolean"
            },
            "requiresSignaling": {
              "type": "boolean"
            }
          }
        },
        "sharedArrayBuffer": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "requires": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["COOP", "COEP"]
              }
            }
          }
        }
      }
    },
    "storage": {
      "type": "object",
      "description": "Storage capabilities",
      "properties": {
        "indexedDB": {
          "type": "boolean"
        },
        "opfs": {
          "type": "boolean",
          "description": "Origin Private File System"
        },
        "cacheAPI": {
          "type": "boolean"
        },
        "localStorage": {
          "type": "boolean"
        },
        "sessionStorage": {
          "type": "boolean"
        }
      }
    },
    "compute": {
      "type": "object",
      "description": "Compute capabilities",
      "properties": {
        "wasm": {
          "type": "boolean",
          "description": "Can run WebAssembly"
        },
        "wasmThreads": {
          "type": "boolean",
          "description": "Can use WASM threads"
        },
        "simd": {
          "type": "boolean",
          "description": "Can use WASM SIMD"
        },
        "offscreenCanvas": {
          "type": "boolean",
          "description": "Can use OffscreenCanvas"
        }
      }
    },
    "crypto": {
      "type": "object",
      "description": "Cryptographic capabilities",
      "properties": {
        "subtle": {
          "type": "boolean",
          "description": "Has crypto.subtle API"
        },
        "algorithms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Supported algorithms (Ed25519, X25519, AES-GCM, etc.)"
        }
      }
    },
    "identity": {
      "type": "object",
      "description": "Cryptographic identity",
      "properties": {
        "publicKey": {
          "type": "string",
          "description": "Base64url-encoded Ed25519 public key (32 bytes)"
        },
        "algorithm": {
          "type": "string",
          "enum": ["Ed25519"],
          "description": "Identity key algorithm (Ed25519 only)"
        },
        "derivedAddresses": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Virtual IPv6 address (ULA format)"
          }
        }
      }
    },
    "services": {
      "type": "array",
      "description": "Services provided by this pod",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "methods": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "Resource hints",
      "properties": {
        "memoryMB": {
          "type": "number",
          "description": "Approximate memory usage"
        },
        "cpuPercent": {
          "type": "number",
          "description": "Approximate CPU usage (0-100)"
        },
        "load": {
          "type": "number",
          "description": "Current load factor (0-1)"
        }
      }
    },
    "scopes": {
      "type": "array",
      "description": "Capability scopes this pod is authorized for (see capability-scope-grammar.md)",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+(?:/[a-z0-9-]+)*:[a-z0-9-]+|\\*$",
        "description": "Scope string in namespace:action format (e.g., 'data:read', 'canvas:write', 'storage:*')"
      }
    },
    "metadata": {
      "type": "object",
      "description": "User-defined metadata",
      "additionalProperties": true
    }
  }
}
