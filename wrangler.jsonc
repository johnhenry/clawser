{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clawser",
  "compatibility_date": "2026-07-04",
  "assets": {
    "directory": "./web",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "clawser.erisera.com",
      "custom_domain": true
    }
  ]
}
